{
  "title": "MERT4 — CouchDB İzleme",
  "uid": "mert4-couchdb",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "timezone": "browser",
  "tags": ["couchdb", "mert4"],
  "annotations": {
    "list": [{
      "builtIn": 1, "datasource": { "type": "grafana", "uid": "-- Grafana --" },
      "enable": true, "hide": true, "iconColor": "rgba(0, 211, 255, 1)", "name": "Annotations & Alerts", "type": "dashboard"
    }]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "CouchDB Durumu",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "ÇALIŞIYOR", "color": "green", "index": 0 }, "0": { "text": "ÇÖKTÜ", "color": "red", "index": 1 } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "up{job=\"couchdb\"}", "legendFormat": "", "refId": "A" }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Toplam Kayıt",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(couchdb_database_info_doc_count)", "legendFormat": "Toplam", "refId": "A" }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Toplam Disk Boyutu",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 104857600 }, { "color": "red", "value": 524288000 }] }
        }
      },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(couchdb_database_info_sizes_file)", "legendFormat": "Disk", "refId": "A" }]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Silinen Kayıt (Tombstone)",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 500 }, { "color": "red", "value": 2000 }] }
        }
      },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(couchdb_database_info_doc_del_count)", "legendFormat": "Silinen", "refId": "A" }]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "HTTP Okuma/sn",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(couchdb_httpd_request_methods_total{method=\"GET\"}[5m])", "legendFormat": "GET/sn", "refId": "A" }]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "HTTP Yazma/sn",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(couchdb_httpd_request_methods_total{method=~\"PUT|POST|DELETE\"}[5m])", "legendFormat": "Yazma/sn", "refId": "A" }]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Kayıt Sayısı — Tablolara Göre",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "couchdb_database_info_doc_count",
        "legendFormat": "{{ db }}",
        "refId": "A"
      }]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "HTTP İstek Oranları",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 8 },
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(couchdb_httpd_request_methods_total{method=\"GET\"}[5m])", "legendFormat": "GET", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(couchdb_httpd_request_methods_total{method=\"PUT\"}[5m])", "legendFormat": "PUT", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(couchdb_httpd_request_methods_total{method=\"POST\"}[5m])", "legendFormat": "POST", "refId": "C" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(couchdb_httpd_request_methods_total{method=\"DELETE\"}[5m])", "legendFormat": "DELETE", "refId": "D" }
      ]
    },
    {
      "id": 9,
      "type": "bargauge",
      "title": "Disk Kullanımı — Tablolara Göre",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "displayMode": "gradient",
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 10485760 }, { "color": "red", "value": 104857600 }] }
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "topk(16, couchdb_database_info_sizes_file)",
        "legendFormat": "{{ db }}",
        "refId": "A"
      }]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "HTTP Durum Kodları (Hatalar)",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "2xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "4xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "5xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(couchdb_httpd_status_codes_total{code=~\"2..\"}[5m]))", "legendFormat": "2xx", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(couchdb_httpd_status_codes_total{code=~\"4..\"}[5m]))", "legendFormat": "4xx", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(couchdb_httpd_status_codes_total{code=~\"5..\"}[5m]))", "legendFormat": "5xx", "refId": "C" }
      ]
    },
    {
      "id": 11,
      "type": "table",
      "title": "Tablo Özeti — Anlık Durum",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "showHeader": true,
        "footer": { "show": true, "reducer": ["sum"], "countRows": false, "fields": ["doc_count", "del_count", "disk_bytes"] }
      },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Disk" }, "properties": [{ "id": "unit", "value": "bytes" }] },
          { "matcher": { "id": "byName", "options": "Kayıt" }, "properties": [{ "id": "custom.width", "value": 100 }] },
          { "matcher": { "id": "byName", "options": "Silinen" }, "properties": [{ "id": "custom.width", "value": 100 }] }
        ]
      },
      "transformations": [
        { "id": "merge", "options": {} },
        { "id": "organize", "options": {
          "renameByName": {
            "db": "Veritabanı",
            "Value #doc_count": "Kayıt",
            "Value #del_count": "Silinen",
            "Value #disk": "Disk"
          }
        }}
      ],
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "couchdb_database_info_doc_count", "legendFormat": "{{db}}", "refId": "doc_count", "instant": true },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "couchdb_database_info_doc_del_count", "legendFormat": "{{db}}", "refId": "del_count", "instant": true },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "couchdb_database_info_sizes_file", "legendFormat": "{{db}}", "refId": "disk", "instant": true }
      ]
    }
  ]
}
